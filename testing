<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Base Cleaning — Site Report</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root {
  --navy:#0a0f1e;--navy2:#111829;--navy3:#1a2540;--blue:#1e7fff;--cyan:#00d4ff;
  --white:#f5f7fa;--grey:#8a96ad;--lgrey:#c8d0df;--green:#00c853;--amber:#f5a623;--red:#ff3b30;
  --fd:'Barlow Condensed',sans-serif;--fb:'DM Sans',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--navy);color:var(--white);font-family:var(--fb);font-size:15px;min-height:100vh;padding-bottom:60px;}
.topbar{background:var(--navy2);border-bottom:2px solid var(--cyan);padding:0 20px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.topbar-logo{font-family:var(--fd);font-size:20px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;}
.topbar-logo span{color:var(--cyan);}
.topbar-right{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--grey);}
.container{max-width:640px;margin:0 auto;padding:20px 16px;}
.step-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
.step-num{width:32px;height:32px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:15px;font-weight:700;flex-shrink:0;}
.step-title{font-family:var(--fd);font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
.card{background:var(--navy2);border:1px solid var(--navy3);border-radius:10px;padding:18px;margin-bottom:14px;}
.card-title{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);margin-bottom:10px;}
label{display:block;font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--grey);margin-bottom:6px;}
input[type=text],input[type=date],input[type=time],select,textarea{width:100%;background:rgba(255,255,255,.05);border:1px solid var(--navy3);border-radius:7px;padding:11px 14px;font-size:14px;font-family:var(--fb);color:var(--white);outline:none;transition:border-color .2s;-webkit-appearance:none;}
input:focus,select:focus,textarea:focus{border-color:var(--blue);background:rgba(30,127,255,.07);}
input::placeholder,textarea::placeholder{color:var(--grey);}
select option{background:var(--navy2);}
textarea{resize:vertical;min-height:80px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-group{margin-bottom:14px;}
.shift-toggle{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;}
.shift-btn{padding:12px;border-radius:8px;border:1.5px solid var(--navy3);background:transparent;color:var(--grey);font-family:var(--fd);font-size:15px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:3px;}
.shift-btn span{font-size:10px;font-family:var(--fb);font-weight:400;}
.shift-btn.active.morning{border-color:var(--amber);color:var(--amber);background:rgba(245,166,35,.08);}
.shift-btn.active.afternoon{border-color:var(--blue);color:var(--blue);background:rgba(30,127,255,.08);}
.shift-btn.active.night{border-color:var(--cyan);color:var(--cyan);background:rgba(0,212,255,.08);}
.areas-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.area-card{background:var(--navy);border:1.5px solid var(--navy3);border-radius:8px;padding:12px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.area-card.has-photo{border-color:var(--green);}
.area-card.has-issue{border-color:var(--red);}
.area-card-name{font-family:var(--fd);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px;}
.area-card-status{font-size:11px;color:var(--grey);}
.area-card.has-photo .area-card-status{color:var(--green);}
.area-card.has-issue .area-card-status{color:var(--red);}
.area-thumb{width:100%;height:70px;object-fit:cover;border-radius:5px;margin-top:8px;display:none;}
.area-card.has-photo .area-thumb{display:block;}
.area-dot{position:absolute;top:8px;right:8px;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;}
.dot-clean{background:var(--green);display:none;}
.dot-issue{background:var(--red);display:none;}
.area-card.has-photo:not(.has-issue) .dot-clean{display:flex;}
.area-card.has-issue .dot-issue{display:flex;}
.area-card.has-issue .dot-clean{display:none;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:200;display:none;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:var(--navy2);border-radius:16px 16px 0 0;border-top:2px solid var(--blue);width:100%;max-width:640px;padding:22px 18px 36px;animation:sup .22s ease;max-height:90vh;overflow-y:auto;}
@keyframes sup{from{transform:translateY(100%);}to{transform:translateY(0);}}
.modal-title{font-family:var(--fd);font-size:17px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;}
.modal-close{background:var(--navy3);border:none;color:var(--grey);width:26px;height:26px;border-radius:50%;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;}
.upload-wrap{border:2px dashed var(--navy3);border-radius:10px;padding:24px 16px;text-align:center;cursor:pointer;transition:border-color .2s;margin-bottom:12px;position:relative;}
.upload-wrap:hover{border-color:var(--blue);}
.upload-wrap input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.upload-text{font-size:13px;color:var(--grey);margin-top:6px;}
.preview-wrap{position:relative;margin-bottom:12px;}
.preview-img{width:100%;max-height:200px;object-fit:cover;border-radius:8px;display:none;}
.preview-img.show{display:block;}
.remove-btn{position:absolute;top:8px;right:8px;background:var(--red);border:none;color:white;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:12px;display:none;align-items:center;justify-content:center;}
.preview-img.show~.remove-btn{display:flex;}
.status-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
.status-btn{padding:10px;border-radius:7px;border:1.5px solid var(--navy3);background:transparent;font-family:var(--fb);font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;color:var(--grey);}
.status-btn.clean.on{border-color:var(--green);color:var(--green);background:rgba(0,200,83,.08);}
.status-btn.issue.on{border-color:var(--red);color:var(--red);background:rgba(255,59,48,.08);}
.btn{width:100%;padding:14px;border-radius:8px;border:none;font-family:var(--fb);font-size:14px;font-weight:600;letter-spacing:.03em;cursor:pointer;transition:all .15s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn-blue{background:var(--blue);color:white;}
.btn-blue:hover{background:#4da3ff;}
.btn-grey{background:var(--navy3);color:var(--lgrey);}
.btn-green{background:var(--green);color:white;}
.btn-outline{background:transparent;border:1.5px solid var(--navy3);color:var(--lgrey);margin-bottom:10px;}
.progress-bar{background:var(--navy3);border-radius:4px;height:5px;margin-bottom:20px;overflow:hidden;}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan));border-radius:4px;transition:width .4s;}
.sum-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--navy3);font-size:14px;}
.sum-row:last-child{border-bottom:none;}
.sum-lbl{color:var(--grey);}
.sum-val{font-weight:600;}
.badge{display:inline-flex;align-items:center;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;}
.b-green{background:rgba(0,200,83,.15);color:var(--green);}
.b-red{background:rgba(255,59,48,.15);color:var(--red);}
.b-grey{background:var(--navy3);color:var(--grey);}
.area-sum-item{background:var(--navy);border-radius:8px;padding:12px;display:flex;gap:10px;margin-bottom:8px;}
.area-sum-thumb{width:48px;height:48px;border-radius:6px;flex-shrink:0;background:var(--navy3);display:flex;align-items:center;justify-content:center;color:var(--grey);font-size:16px;overflow:hidden;}
.area-sum-thumb img{width:100%;height:100%;object-fit:cover;}
.area-sum-name{font-family:var(--fd);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px;}
.area-sum-note{font-size:12px;color:var(--grey);line-height:1.4;}
.success-wrap{text-align:center;padding:36px 16px;}
.success-icon{width:68px;height:68px;border-radius:50%;background:rgba(0,200,83,.12);border:2px solid var(--green);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 18px;}
.success-title{font-family:var(--fd);font-size:24px;font-weight:800;text-transform:uppercase;margin-bottom:6px;}
.success-sub{font-size:13px;color:var(--grey);margin-bottom:24px;line-height:1.5;}
.divider{height:1px;background:var(--navy3);margin:18px 0;}
.past-item{background:var(--navy);border-radius:8px;padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;}
.past-site{font-family:var(--fd);font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;}
.past-meta{font-size:12px;color:var(--grey);margin-top:2px;}
@media(max-width:400px){.areas-grid{grid-template-columns:1fr;}.form-row{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="topbar">
  <div class="topbar-logo">Base<span>.</span>Cleaning</div>
  <div class="topbar-right" id="top-date"></div>
</div>
<div id="s1" class="container">
  <div class="progress-bar"><div class="progress-fill" style="width:20%"></div></div>
  <div class="step-header"><div class="step-num">1</div><div class="step-title">Job Details</div></div>
  <div class="card">
    <div class="card-title">Site Information</div>
    <div class="form-group">
      <label>Site Name</label>
      <select id="site">
        <option value="">Select site...</option>
        <option>Liverpool Plaza</option>
        <option>Gym — Site A</option>
        <option>Gym — Site B
